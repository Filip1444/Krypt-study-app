{
  "name": "study-app",
  "version": "1.0.0",
  "description": "Study desktop app",
  "author": "Study App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder -p never",
    "dist:win": "electron-builder --win -p never",
    "dist:mac": "electron-builder --mac --config.directories.output=release_macOS -p never"
  },
  "build": {
    "appId": "com.studyapp.desktop",
    "productName": "Study App",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "sign": null,
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.education"
    },
    "forceCodeSigning": false
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "docx": "^9.6.1"
  }
}
