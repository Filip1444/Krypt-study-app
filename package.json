{
  "name": "krypt",
  "version": "1.1.1",
  "description": "KRYPT desktop app",
  "author": "KRYPT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder -p never",
    "dist:win": "electron-builder --win -p never",
    "dist:mac": "electron-builder --mac --config.directories.output=release_macOS -p never"
  },
  "build": {
    "appId": "com.krypt.desktop",
    "productName": "KRYPT",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.education"
    },
    "forceCodeSigning": false
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "docx": "^9.6.1"
  }
}
